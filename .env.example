# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zo_registry"

# Admin API (optional; if unset, admin routes return 401)
ADMIN_TOKEN=

# Public URL of the app (for archive URLs in API responses)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Path to templates directory (default: repo templates/ relative to app cwd)
# TEMPLATES_DIR=./templates
